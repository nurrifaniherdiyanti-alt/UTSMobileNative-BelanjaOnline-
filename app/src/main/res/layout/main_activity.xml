<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/header_gradient"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="48dp"
            android:paddingEnd="24dp"
            android:paddingBottom="32dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🛒" android:textSize="36sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ShopEasy" android:textColor="#FFFFFF" android:textSize="30sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sistem Belanja Online Sederhana" android:textColor="#CCE0FF" android:textSize="13sp"/>
        </LinearLayout>

        <!-- FORM CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="-18dp"
            android:layout_marginEnd="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Label Data Pembeli -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="👤 DATA PEMBELI" android:textColor="#2563EB" android:textSize="11sp"
                    android:textStyle="bold" android:background="@drawable/label_bg"
                    android:paddingStart="12dp" android:paddingEnd="12dp" android:paddingTop="4dp"
                    android:paddingBottom="4dp" android:layout_marginBottom="10dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nama Pembeli" android:textColor="#64748B" android:textSize="12sp" android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/etNamaPembeli" android:layout_width="match_parent" android:layout_height="48dp"
                    android:background="@drawable/input_bg" android:paddingStart="14dp" android:paddingEnd="14dp"
                    android:inputType="textPersonName" android:textColor="#1E293B" android:textSize="14sp"
                    android:hint="Masukkan nama pembeli" android:textColorHint="#94A3B8" android:layout_marginBottom="12dp"/>

                <!-- Label Data Produk -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📦 DATA PRODUK" android:textColor="#059669" android:textSize="11sp"
                    android:textStyle="bold" android:background="@drawable/label_bg_green"
                    android:paddingStart="12dp" android:paddingEnd="12dp" android:paddingTop="4dp"
                    android:paddingBottom="4dp" android:layout_marginBottom="10dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nama Produk" android:textColor="#64748B" android:textSize="12sp" android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/etNamaProduk" android:layout_width="match_parent" android:layout_height="48dp"
                    android:background="@drawable/input_bg" android:paddingStart="14dp" android:paddingEnd="14dp"
                    android:inputType="text" android:textColor="#1E293B" android:textSize="14sp"
                    android:hint="Masukkan nama produk" android:textColorHint="#94A3B8" android:layout_marginBottom="12dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Harga Satuan (Rp)" android:textColor="#64748B" android:textSize="12sp" android:layout_marginBottom="4dp"/>
                        <EditText android:id="@+id/etHargaSatuan" android:layout_width="match_parent" android:layout_height="48dp"
                            android:background="@drawable/input_bg" android:paddingStart="14dp" android:paddingEnd="14dp"
                            android:inputType="numberDecimal" android:textColor="#1E293B" android:textSize="14sp"
                            android:hint="0" android:textColorHint="#94A3B8"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Jumlah Barang" android:textColor="#64748B" android:textSize="12sp" android:layout_marginBottom="4dp"/>
                        <EditText android:id="@+id/etJumlahBarang" android:layout_width="match_parent" android:layout_height="48dp"
                            android:background="@drawable/input_bg" android:paddingStart="14dp" android:paddingEnd="14dp"
                            android:inputType="number" android:textColor="#1E293B" android:textSize="14sp"
                            android:hint="0" android:textColorHint="#94A3B8"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Label Pengiriman -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🚚 PENGIRIMAN &amp; MEMBER" android:textColor="#D97706" android:textSize="11sp"
                    android:textStyle="bold" android:background="@drawable/label_bg_orange"
                    android:paddingStart="12dp" android:paddingEnd="12dp" android:paddingTop="4dp"
                    android:paddingBottom="4dp" android:layout_marginBottom="10dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Kota Tujuan / Ongkos Kirim" android:textColor="#64748B" android:textSize="12sp" android:layout_marginBottom="4dp"/>
                <Spinner android:id="@+id/spinnerKota" android:layout_width="match_parent" android:layout_height="48dp"
                    android:background="@drawable/spinner_bg_shape" android:paddingStart="14dp" android:paddingEnd="14dp" android:layout_marginBottom="12dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Kategori Member / Jenis Pelanggan" android:textColor="#64748B" android:textSize="12sp" android:layout_marginBottom="4dp"/>
                <Spinner android:id="@+id/spinnerMember" android:layout_width="match_parent" android:layout_height="48dp"
                    android:background="@drawable/spinner_bg_shape" android:paddingStart="14dp" android:paddingEnd="14dp" android:layout_marginBottom="20dp"/>

                <!-- Tombol -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnReset"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="Reset"
                        android:textColor="#2563EB"
                        android:textAllCaps="false"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:singleLine="true"
                        app:backgroundTint="#EFF6FF"
                        app:strokeColor="#2563EB"
                        app:strokeWidth="1dp"
                        app:cornerRadius="14dp"
                        app:icon="@android:drawable/ic_menu_revert"
                        app:iconTint="#2563EB"
                        app:iconSize="16dp"
                        app:iconGravity="textStart"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnHitung"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="Proses Belanja"
                        android:textColor="#FFFFFF"
                        android:textAllCaps="false"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:singleLine="true"
                        app:backgroundTint="#2563EB"
                        app:cornerRadius="14dp"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- OUTPUT CARD -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardOutput"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginStart="16dp" android:layout_marginTop="20dp" android:layout_marginEnd="16dp"
            android:visibility="gone"
            app:cardCornerRadius="20dp" app:cardElevation="10dp" app:cardBackgroundColor="#FFFFFF">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:background="@drawable/output_header_bg" android:padding="14dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="🧾 RINGKASAN TRANSAKSI" android:textColor="#FFFFFF"
                        android:textSize="14sp" android:textStyle="bold"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E2E8F0" android:layout_marginTop="14dp" android:layout_marginBottom="10dp"/>

                <!-- Baris output -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Nama Pembeli" android:textColor="#94A3B8" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvOutNamaPembeli" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="end" android:textColor="#1E293B" android:textSize="13sp" android:textStyle="bold"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Nama Produk" android:textColor="#94A3B8" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvOutNamaProduk" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="end" android:textColor="#1E293B" android:textSize="13sp" android:textStyle="bold"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Harga Satuan" android:textColor="#94A3B8" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvOutHargaSatuan" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="end" android:textColor="#1E293B" android:textSize="13sp" android:textStyle="bold"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Jumlah Barang" android:textColor="#94A3B8" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvOutJumlahBarang" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="end" android:textColor="#1E293B" android:textSize="13sp" android:textStyle="bold"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E2E8F0" android:layout_marginBottom="8dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Subtotal" android:textColor="#94A3B8" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvOutSubtotal" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="end" android:textColor="#1E293B" android:textSize="13sp" android:textStyle="bold"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Diskon" android:textColor="#94A3B8" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvOutDiskon" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="end" android:textColor="#059669" android:textSize="13sp" android:textStyle="bold"/>
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Ongkos Kirim" android:textColor="#94A3B8" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvOutOngkir" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="end" android:textColor="#D97706" android:textSize="13sp" android:textStyle="bold"/>
                </LinearLayout>

                <!-- Total -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:background="@drawable/total_bg" android:orientation="horizontal"
                    android:padding="14dp" android:layout_marginTop="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="TOTAL BAYAR" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/tvOutTotalBayar" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="end" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"/>
                </LinearLayout>

                <!-- Promo -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:background="@drawable/promo_bg" android:orientation="vertical"
                    android:padding="14dp" android:layout_marginTop="12dp">
                    <TextView android:id="@+id/tvOutStatusPromo" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="13sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/tvOutKeteranganPromo" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#475569" android:textSize="12sp" android:layout_marginTop="4dp"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="20dp" android:gravity="center"
            android:text="© 2026 ShopEasy" android:textColor="#94A3B8" android:textSize="11sp"/>

    </LinearLayout>
</ScrollView>